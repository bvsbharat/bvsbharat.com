---
import Layout from "./Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Hr from "@/components/Hr.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import Tag from "@/components/Tag.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import EditPost from "@/components/EditPost.astro";
import { getReadingTime } from "@/utils/readingTime";
import { render, type CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDatetime, modDatetime, tags, heroImage, ogImage } = post.data;
const { Content } = await render(post);
const readingTime = getReadingTime(post.body ?? "");
const postUrl = new URL(Astro.url.pathname, Astro.site).href;

const sparkTransition = {
  forwards: {
    old: [{ name: "sparkOut", duration: "0.25s", easing: "ease-in", fillMode: "forwards" }],
    new: [{ name: "sparkIn", duration: "0.5s", easing: "ease-out", fillMode: "backwards" }],
  },
  backwards: {
    old: [{ name: "sparkOut", duration: "0.25s", easing: "ease-in", fillMode: "forwards" }],
    new: [{ name: "sparkIn", duration: "0.5s", easing: "ease-out", fillMode: "backwards" }],
  },
};
---

<Layout
  title={title}
  description={description}
  ogImage={ogImage ?? heroImage}
  pubDatetime={pubDatetime}
  modDatetime={modDatetime}
  scrollSmooth
  article={{
    title,
    description,
    pubDatetime,
    modDatetime,
    heroImage,
    url: postUrl,
  }}
>
  <Header />
  <main id="main-content" class="mx-auto w-full flex-1 px-6 pb-12" style="max-width:1020px">
    <article data-pagefind-body>
      <header class="mb-8 mt-8">
        <h1
          transition:name={post.id.replace(/\.(md|mdx)$/, "").replace(/\//g, "-")}
          transition:animate={sparkTransition}
          class="text-2xl font-bold leading-tight tracking-wide text-accent sm:text-3xl"
        >{title}</h1>
        <div class="mt-3 flex flex-wrap items-center gap-3 text-sm opacity-70">
          <FormattedDate date={pubDatetime} />
          {modDatetime && (
            <span class="italic">
              Updated: <FormattedDate date={modDatetime} />
            </span>
          )}
          <span class="italic">&bull; {readingTime}</span>
        </div>
        {tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {tags.map((tag) => <Tag tag={tag} />)}
          </div>
        )}
      </header>

      {heroImage && heroImage.includes("youtube.com") ? (() => {
        const url = new URL(heroImage);
        const videoId = url.searchParams.get("v") || url.pathname.split("/").pop();
        return (
          <div class="mb-8 aspect-video w-full overflow-hidden rounded-lg border-2 border-border">
            <iframe
              src={`https://www.youtube.com/embed/${videoId}`}
              title={title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="h-full w-full"
            />
          </div>
        );
      })() : heroImage && (
        <img
          src={heroImage}
          alt={title}
          transition:name={`hero-${post.id.replace(/\.(md|mdx)$/, "").replace(/\//g, "-")}`}
          class="mb-8 w-full rounded-lg border-2 border-border transition-shadow duration-300 hover:shadow-lg"
        />
      )}

      <div class="prose prose-lg max-w-none">
        <Content />
      </div>
    </article>

    <Hr />

    <div class="flex flex-wrap items-center justify-between gap-4 mt-2">
      <ShareLinks title={title} url={Astro.url.href} />
      <EditPost filePath={post.id} />
    </div>
  </main>
  <Footer />
</Layout>

<script>
  // Lazy-render mermaid diagrams. Shiki turns ```mermaid``` fences into
  // <pre data-language="mermaid"><code>…</code></pre> — we swap those for
  // mermaid-rendered SVGs only on pages that contain one.
  // Force light theme + white panel background in both color schemes so the
  // diagrams are always legible (mermaid's dark theme drops stroke contrast
  // against this site's dark surface).
  const mermaidBlocks = document.querySelectorAll('pre[data-language="mermaid"]');
  if (mermaidBlocks.length > 0) {
    const mermaid = (
      await import(
        "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs"
      )
    ).default;
    mermaid.initialize({
      startOnLoad: false,
      theme: "default",
      securityLevel: "loose",
      themeVariables: {
        background: "#ffffff",
        fontFamily:
          "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif",
        fontSize: "14px",
      },
      flowchart: { curve: "basis", htmlLabels: true, padding: 12 },
      sequence: { useMaxWidth: true, mirrorActors: false, boxMargin: 8 },
    });
    mermaidBlocks.forEach((block, i) => {
      const source = (block.textContent || "").trim();
      const wrapper = document.createElement("div");
      wrapper.className =
        "mermaid not-prose my-6 flex justify-center bg-white rounded-lg p-4 overflow-x-auto border border-slate-200";
      wrapper.id = `mermaid-${i}`;
      wrapper.style.colorScheme = "light";
      wrapper.textContent = source;
      block.replaceWith(wrapper);
    });
    await mermaid.run({ querySelector: ".mermaid" });
  }
</script>
