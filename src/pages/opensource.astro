---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const projects = [
  {
    name: "bvsbharat/SuperAgent.app",
    description: "Full-stack voice AI agent platform with real-time transcription and multi-step task execution.",
    github: "https://github.com/bvsbharat/SuperAgent.app",
    language: "TypeScript",
    languageColor: "#3178C6",
    featured: true,
  },
  {
    name: "bvsbharat/Optimus.ai",
    description: "Multi-agent orchestration framework with advanced state management and async task processing.",
    github: "https://github.com/bvsbharat/Optimus.ai",
    language: "Python",
    languageColor: "#3776AB",
    featured: true,
  },
  {
    name: "bvsbharat/gemini-5head",
    description: "Advanced multi-modal AI reasoning engine with real-time web search and artifact generation.",
    github: "https://github.com/bvsbharat/gemini-5head",
    language: "Python",
    languageColor: "#3776AB",
  },
  {
    name: "bvsbharat/landingai-graph",
    description: "Graph-based vision AI framework for document processing and visual intelligence.",
    github: "https://github.com/bvsbharat/landingai-graph",
    language: "Python",
    languageColor: "#3776AB",
  },
  {
    name: "bvsbharat/glass",
    description: "Real-time event streaming and processing engine for agent pipelines.",
    github: "https://github.com/bvsbharat/glass",
    language: "Rust",
    languageColor: "#CE422B",
  },
  {
    name: "bvsbharat/homebrew-superagents",
    description: "Mac command center with agent orchestration capabilities – manage and coordinate multiple AI agents.",
    github: "https://github.com/bvsbharat/homebrew-superagents",
    language: "Swift",
    languageColor: "#F05138",
  },
  {
    name: "bvsbharat/bolt.new",
    description: "Fork and contributions to the bolt.new full-stack web development agent.",
    github: "https://github.com/bvsbharat/bolt.new",
    language: "TypeScript",
    languageColor: "#3178C6",
  },
  {
    name: "bvsbharat/reunite",
    description: "AI-powered missing person identification and recovery system.",
    github: "https://github.com/bvsbharat/reunite",
    language: "Python",
    languageColor: "#3776AB",
  },
  {
    name: "bvsbharat/Asidely.app",
    description: "Social network for builders sharing side projects and gaining visibility.",
    github: "https://github.com/bvsbharat/Asidely.app",
    language: "TypeScript",
    languageColor: "#3178C6",
  },
  {
    name: "bvsbharat/openenv-hack-hackathon",
    description: "Meta's OpenEnv framework hackathon – building agentic AI environments for RL and automation.",
    github: "https://github.com/bvsbharat/openenv-hack-hackathon",
    language: "Markdown",
    languageColor: "#083fa1",
  },
  {
    name: "bvsbharat/speech-to-code",
    description: "Voice-driven code generation with real-time streaming and editor integration.",
    github: "https://github.com/bvsbharat/speech-to-code",
    language: "TypeScript",
    languageColor: "#3178C6",
  },
];
---

<Layout title="Open Source | Bharat Bhavnasi">
  <div class="container">
    <h1>Open Source Projects</h1>
    <p class="description">
      Curated collection of my open source projects spanning agent development, AI infrastructure, and
      full-stack applications. Each project focuses on building robust, production-ready tools for the
      agentic AI ecosystem.
    </p>

    <div class="projects-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 3rem;
    max-width: 700px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }
</style>